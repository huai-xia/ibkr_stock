# ============================================
# IBKR 智能交易助手 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# --- IBKR 连接配置 ---
# IB Gateway Paper Trading（默认推荐）
IBKR_HOST=127.0.0.1
IBKR_PORT=4001          # 4001=Gateway Paper, 4002=Gateway Live
IBKR_CLIENT_ID=1
# TWS 备选端口: 7496=Paper, 7497=Live

# --- IBKR 账户 ---
IBKR_ACCOUNT_ID=DU000000

# --- 通知渠道（选一个即可）---

# 方案一：Server酱 — 推送到个人微信（推荐，微信扫码即用）
# 访问 https://sct.ftqq.com/ 微信扫码 → 获取 SendKey
SERVERCHAN_SEND_KEY=YOUR_SEND_KEY_HERE

# 方案二：企业微信机器人 — 推送到企业微信
# 在企业微信中创建群聊 → 群设置 → 群机器人 → 添加 → 复制 Webhook URL
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# 方案三：QQ邮箱 SMTP
# QQ邮箱 → 设置 → 账户 → POP3/SMTP → 开启 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code

# --- 新闻 API ---
# Finnhub 免费额度: 60次/分钟（注册 https://finnhub.io/）
FINNHUB_API_KEY=your_finnhub_key_here
# NewsAPI 免费额度（注册 https://newsapi.org/）
NEWSAPI_KEY=your_newsapi_key_here

# --- 远程服务器 ---
REMOTE_HOST=your_remote_host
REMOTE_PORT=22
REMOTE_USER=your_username
REMOTE_DIR=/home/your_username/project
